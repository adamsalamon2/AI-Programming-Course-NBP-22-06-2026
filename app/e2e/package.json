{
  "name": "hardware-copilot-e2e",
  "version": "1.0.0",
  "description": "Playwright E2E tests for Hardware Service Decision Copilot",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:list": "playwright test --list",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:invalid": "playwright test tests/invalid-submission.spec.ts",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
