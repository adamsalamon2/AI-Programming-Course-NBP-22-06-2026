{
  "$meta": {
    "source": "https://nbp.pl",
    "brand": "Narodowy Bank Polski (NBP)",
    "extractedAt": "2026-06-24"
  },
  "colors": {
    "brand": {
      "primary": "#152E52",
      "accent": "#BDAD7D",
      "link": "#4A74B0",
      "error": "#C0392B",
      "success": "#2E7D32"
    },
    "background": {
      "default": "#FFFFFF",
      "light": "#F7F7F7",
      "muted": "#C4C4C4",
      "dark": "#152E52",
      "overlay": "rgba(21, 46, 82, 0.6)"
    },
    "border": {
      "default": "#BFCEDD",
      "light": "#E5E5E5"
    },
    "text": {
      "primary": "#152E52",
      "body": "#464646",
      "secondary": "#323232",
      "muted": "#707070",
      "link": "#4A74B0",
      "onDark": "#FFFFFF"
    }
  },
  "typography": {
    "fontFamily": {
      "heading": "\"Brygada 1918\", Georgia, \"Times New Roman\", serif",
      "body": "\"Libre Franklin\", -apple-system, Arial, \"Noto Sans\", sans-serif"
    },
    "fontWeights": {
      "thin": 100,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSize": {
      "sm": "13px",
      "base": "15px",
      "md": "16px",
      "lg": "20px",
      "xl": "27px",
      "2xl": "34px"
    },
    "lineHeight": {
      "tight": "1.2",
      "base": "1.55",
      "heading": "1.48",
      "relaxed": "1.8"
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "10": "40px",
    "12": "48px"
  },
  "borderRadius": {
    "none": "0px",
    "xs": "2px",
    "sm": "4px",
    "md": "6px",
    "full": "999px",
    "circle": "50%"
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#4A74B0",
        "color": "#FFFFFF",
        "padding": "6px 12px",
        "borderRadius": "4px",
        "fontSize": "13px",
        "fontWeight": 500,
        "textTransform": "uppercase",
        "border": "0.8px solid #4A74B0"
      },
      "accent": {
        "backgroundColor": "#BDAD7D",
        "color": "#152E52",
        "padding": "12px 27px",
        "borderRadius": "4px",
        "fontSize": "13px",
        "fontWeight": 500,
        "textTransform": "uppercase",
        "border": "0.8px solid transparent"
      }
    },
    "header": {
      "backgroundColor": "#152E52",
      "color": "#FFFFFF",
      "padding": "0px"
    },
    "nav": {
      "color": "#152E52",
      "fontSize": "15px",
      "fontWeight": 400,
      "textTransformTopLevel": "uppercase",
      "topLevelFontWeight": 600
    },
    "input": {
      "backgroundColor": "#FFFFFF",
      "border": "0.8px solid #BFCEDD",
      "borderRadius": "6px",
      "padding": "10px",
      "color": "#464646"
    },
    "heading": {
      "h1": { "color": "#152E52", "fontFamily": "Brygada 1918", "fontSize": "27px", "fontWeight": 500, "lineHeight": "40px" },
      "h2": { "fontFamily": "Brygada 1918", "fontSize": "27px", "fontWeight": 500, "lineHeight": "40px" },
      "h3": { "color": "#333333", "fontFamily": "Libre Franklin", "fontSize": "15px", "fontWeight": 600 }
    }
  }
}
